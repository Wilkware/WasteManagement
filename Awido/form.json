                {
                    "type": "CheckBox",
                    "name": "fractionID30",
                    "visible": false
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "✨ Visualisation ...",
            "items": [
                {
                    "type": "CheckBox",
                    "name": "settingsTileVisu",
                    "caption": "Activate support for Tile Visu?"
                },
                {
                    "type": "List",
                    "name": "settingsTileColors",
                    "caption": "Waste groups:",
                    "add": false,
                    "delete": false,
                    "changeOrder": false,
                    "rowCount": 5,
                    "columns": [
                        {
                            "name": "Type",
                            "caption": "Waste Type:",
                            "save": true,
                            "visible": false
                        },
                        {
                            "name": "Term",
                            "caption": "Generic term:",
                            "save": true,
                            "width": "200px"
                        },
                        {
                            "name": "Color",
                            "caption": "Barrel colour:",
                            "width": "150px",
                            "edit": {
                                "type": "SelectColor",
                                "allowTransparent": false
                            }
                        },
                        {
                            "name": "Match",
                            "caption": "Search term:",
                            "width": "auto",
                            "add": "",
                            "edit": {
                                "type": "ValidationTextBox"
                            }
                        }
                    ]
                },
                {
                    "type": "Label",
                    "label": "HINT: Always separate different search terms with | and do not use spaces!",
                    "italic": true
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "SelectColor",
                            "name": "settingsAccentToday",
                            "caption": "Accent Color (Today):",
                            "allowTransparent": true,
                            "width": "225px"
                        },
                        {
                            "type": "SelectColor",
                            "name": "settingsAccentTomorrow",
                            "caption": "Accent Color (Tomorrow):",
                            "allowTransparent": true,
                            "width": "233px"
                        },
                        {
                            "type": "NumberSpinner",
                            "name": "settingsTonneAlpha",
                            "caption": "Color transparency (thumbnail view):",
                            "digits": 0,
                            "minimum": 0,
                            "maximum": 100,
                            "suffix": "%",
                            "width": "233px"
                        }
                    ]
                },
                {
                    "type": "Label",
                    "label": "HINT: Selecting the transparent color option uses the accent color of the currently selected theme!",
                    "italic": true
                },
                {
                    "type": "CheckBox",
                    "caption": "Use the barrel colour as the background (thumbnail view)?",
                    "name": "settingsTonneColor",
                    "value": true
                },
                {
                    "type": "CheckBox",
                    "name": "settingsHtmlBox",
                    "caption": "Enable support for the old web front-end (HTMLBox)?"
                },
                {
                    "type": "CheckBox",
                    "name": "settingsLookAhead",
                    "caption": "Activate predictive display for the following days?"
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "SelectTime",
                            "name": "settingsLookTime",
                            "caption": "Time:",
                            "width": "250px"
                        },
                        {
                            "type": "Label",
                            "caption": "\nTimes before 0:30 am will not be considered!",
                            "italic": true
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "⚙️ Advanced settings ...",
            "items": [
                {
                    "type": "CheckBox",
                    "name": "activateAWIDO",
                    "caption": "Activate daily update?"
                },
                {
                    "type": "CheckBox",
                    "name": "createVariables",
                    "caption": "Create variables for non-selected disposals?"
                },
                {
                    "type": "SelectScript",
                    "name": "settingsScript",
                    "caption": "Subsequent execution of a script:",
                    "width": "450px"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "ExpansionPanel",
            "caption": "🚀 Execute action ...",
            "items": [
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Button",
                            "name": "updateButton",
                            "caption": "Update",
                            "onClick": "AWIDO_Update($id);",
                            "visible": false
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "🎗️ Source code, donation and licence ...",
            "items": [
                {
                    "type": "Label",
                    "caption": "The software is free of charge for non-commercial use, I would appreciate a donation if you like the module.",
                    "bold": true
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Image",
                            "image": "data:image/svg+xml;base64,",
                            "onClick": "echo 'https://wilkware.github.io/';"
                        },
                        {
                            "type": "Image",
                            "image": "data:image/svg+xml;base64,",
                            "onClick": "echo 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=8816166';"
                        },
                        {
                            "type": "Image",
                            "image": "data:image/svg+xml;base64,",
                            "onClick": "echo 'https://creativecommons.org/licenses/by-nc-sa/4.0/';"
                        }
                    ]
                },
                {
                    "type": "Label",
                    "color": 8421504
                }
            ]
        }
    ],
    "status": [
        {
            "code": 101,
            "icon": "inactive",
            "caption": "Creating instance."
        },
        {
            "code": 102,
            "icon": "active",
            "caption": "Instance active."
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Instance inactive."
        },
        {
            "code": 201,
            "icon": "inactive",
            "caption": "Please select a valid refuse management!"
        },
        {
            "code": 202,
            "icon": "inactive",
            "caption": "Please select a valid place!"
        },
        {
            "code": 203,
            "icon": "inactive",
            "caption": "Please select a valid location/street!"
        },
        {
            "code": 204,
            "icon": "inactive",
            "caption": "Please select a valid street number!"
        },
        {
            "code": 205,
            "icon": "inactive",
            "caption": "Please select a offered disposals!"
        }
    ]
