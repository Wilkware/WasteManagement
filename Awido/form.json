{
    "elements": [
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Image",
                    "image": "data:image/png;base64,",
                    "link": true,
                    "onClick": "echo 'https://wilkware.de';"
                },
                {
                    "type": "ColumnLayout",
                    "items": [
                        {
                            "type": "Label",
                            "label": "AWIDO – Disposal calendar",
                            "bold": true
                        },
                        {
                            "type": "Label",
                            "label": "This module uses the data provided by the AWIDO online service to display upcoming disposal dates."
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "🔗 Online service ...",
            "items": [
                {
                    "type": "Select",
                    "name": "serviceProvider",
                    "caption": "Provider:",
                    "width": "450px",
                    "enabled": false,
                    "options": [
                        {
                            "label": "Please select ...",
                            "value": "null"
                        }
                    ]
                },
                {
                    "type": "Select",
                    "name": "serviceCountry",
                    "caption": "Country:",
                    "width": "450px",
                    "onChange": "IPS_RequestAction($id,'OnChangeCountry',$serviceCountry);",
                    "options": [
                        {
                            "label": "Germany",
                            "value": "de"
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "♻️ Waste management ...",
            "items": [
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Select",
                            "name": "clientID",
                            "caption": "Disposal area:",
                            "width": "450px",
                            "onChange": "IPS_RequestAction($id,'OnChangeClient',$clientID);",
                            "options": [
                                {
                                    "label": "Please select ...",
                                    "value": "null"
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Select",
                            "name": "placeGUID",
                            "caption": "Location:",
                            "width": "450px",
                            "visible": false,
                            "onChange": "IPS_RequestAction($id,'OnChangePlace',$placeGUID);",
                            "options": [
                                {
                                    "label": "Please select ...",
                                    "value": "null"
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "Select",
                            "name": "streetGUID",
                            "caption": "District/Street:",
                            "width": "450px",
                            "visible": false,
                            "onChange": "IPS_RequestAction($id,'OnChangeStreet',$streetGUID);",
                            "options": [
                                {
                                    "label": "Please select ...",
                                    "value": "null"
                                }
                            ]
                        },
                        {
                            "type": "Select",
                            "name": "addonGUID",
                            "caption": "Number:",
                            "width": "450px",
                            "visible": false,
                            "onChange": "IPS_RequestAction($id,'OnChangeAddon',$addonGUID);",
                            "options": [
                                {
                                    "label": "Please select ...",
                                    "value": "null"
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "Label",
                    "name": "labelFraction",
                    "caption": "The following disposals are offered:",
                    "visible": false
                },
                {
                    "type": "CheckBox",
                    "name": "fractionID1",
                    "visible": false
                },
                {
                    "type": "CheckBox",
                    "name": "fractionID2",
                    "visible": false
